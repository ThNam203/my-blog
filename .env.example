# Supabase — find these in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your deployment URL — used as the OAuth redirect base (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Email address that gets admin privileges (can delete any comment)
ADMIN_EMAIL=your@email.com

# Resend (https://resend.com)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=          # newsletter list id
RESEND_NOTIFY_FROM=          # verified sender; used for comment + confession notify emails

# One secret for both Supabase Database Webhooks (comments INSERT + confessions INSERT).
# Webhook HTTP header: x-webhook-secret: <same value>
NOTIFY_WEBHOOK_SECRET=
