# Supabase — find these in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your deployment URL — used as the OAuth redirect base (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Email address that gets admin privileges (can delete any comment)
ADMIN_EMAIL=your@email.com

RESEND_API_KEY=
RESEND_AUDIENCE_ID=          # newsletter list id
COMMENT_WEBHOOK_SECRET=      # any random string, must match Supabase webhook header
COMMENT_NOTIFY_TO=           # falls back to ADMIN_EMAIL
COMMENT_NOTIFY_FROM=         # must be a verified Resend sender
CONFESSION_NOTIFY_TO=        # falls back to ADMIN_EMAIL
